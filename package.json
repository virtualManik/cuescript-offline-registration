{
  "name": "cuescript-offline-registration",
  "productName": "CueScript Offline Registration",
  "version": "1.5.1",
  "description": "Generate CueiT offline registration (.csr) files",
  "main": ".vite/build/main.js",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "package:win": "electron-forge package --platform=win32 --arch=x64",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform=win32 --arch=x64",
    "make:win:debug": "set DEBUG=electron-forge:* electron-packager&& electron-forge make --platform=win32 --arch=x64",
    "publish": "electron-forge publish",
    "test": "node --test",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "Manik",
    "email": "m.soomro@cuescript.tv"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "43.1.0",
    "tailwindcss": "^4.3.2",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
